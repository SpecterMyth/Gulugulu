{"appid":4956830,"seed":{"withIcons":true,"iconBase":"https://raw.githubusercontent.com/SpecterMyth/Gulugulu/main/assets/steam-icons","elementOrder":["normal","fire","electric","water","grass","ice"],"elementsZh":{"normal":"一般","fire":"火","electric":"电","water":"水","grass":"草","ice":"冰"},"species":[{"codename":"guluduck","def":101,"tier":1,"elements":["normal"],"nameZh":"咕噜鸭","desc":"换上黑白礼服的嘴硬奶鸭，口头禅\"嘎？这合理吗？\""},{"codename":"emberfox","def":102,"tier":1,"elements":["fire"],"nameZh":"炎尾狐","desc":"急性子的高个子奶狐，火焰尾巴比头还高，随情绪忽大忽小"},{"codename":"voltmouse","def":103,"tier":1,"elements":["electric"],"nameZh":"啾雷鼠","desc":"巴掌大的迷你雷鼠，兴奋时会把静电传给别人"},{"codename":"bubblefrog","def":104,"tier":1,"elements":["water"],"nameZh":"气泡鲸","desc":"飘在半空的圆滚小鲸，慢性子乐天派，喷水柱里装着今天的心情"},{"codename":"sproutcap","def":105,"tier":1,"elements":["grass"],"nameZh":"嫩芽菇","desc":"顶着比身体大三倍的菌帽，晒到太阳会不自觉左右摇摆"},{"codename":"frostpeng","def":106,"tier":1,"elements":["ice"],"nameZh":"霜雪怪","desc":"毛茸茸的壮实小雪怪，高冷话少，其实最怕别人不理它"},{"codename":"guluswan","def":219,"tier":2,"elements":["normal"],"nameZh":"咕噜天鹅","desc":"黑白礼服的优雅天鹅，激动时仍会\"嘎\"地破音"},{"codename":"infernofox","def":207,"tier":2,"elements":["fire"],"nameZh":"炎狱狐","desc":"三条火焰尾的大狐狸，走过之处留下小小焦印"},{"codename":"thunderking","def":201,"tier":2,"elements":["electric"],"nameZh":"雷霆鼠皇","desc":"头戴静电王冠的胖鼠皇，打个哈欠都带雷声"},{"codename":"tidefrog","def":221,"tier":2,"elements":["water"],"nameZh":"浪涛鲸","desc":"背驮一朵永不落下的浪花的大鲸，游过带起水雾"},{"codename":"mycobeast","def":212,"tier":2,"elements":["grass"],"nameZh":"菇林兽","desc":"帽子上长着一整片小蘑菇林的温顺巨菇"},{"codename":"glacierpeng","def":216,"tier":2,"elements":["ice"],"nameZh":"极冰雪帝","desc":"披冰晶披风的雪怪皇帝，呼吸凝成雪花"},{"codename":"blazeduck","def":210,"tier":2,"elements":["fire","normal"],"nameZh":"焰羽鸭","desc":"呆毛烧成三簇小火苗的白鸭，尾巴是一撮狐火"},{"codename":"sparkduck","def":205,"tier":2,"elements":["electric","normal"],"nameZh":"闪光鸭","desc":"羽毛噼啪带电的白鸭，摸头会被轻微电到"},{"codename":"rippleduck","def":220,"tier":2,"elements":["water","normal"],"nameZh":"涟漪鸭","desc":"尾巴变成小尾鳍的水灵鸭，走路自带涟漪光环"},{"codename":"mossduck","def":214,"tier":2,"elements":["grass","normal"],"nameZh":"苔羽鸭","desc":"头顶小菇帽、背上长苔藓的悠闲鸭"},{"codename":"frostduck","def":217,"tier":2,"elements":["ice","normal"],"nameZh":"霜羽鸭","desc":"围着蓬蓬霜毛围脖的酷鸭，羽毛结着细霜"},{"codename":"plasmatanuki","def":202,"tier":2,"elements":["fire","electric"],"nameZh":"电浆狐","desc":"圆耳朵的狐狸，火焰尾里裹着一道噼啪电芯"},{"codename":"steamander","def":211,"tier":2,"elements":["water","fire"],"nameZh":"蒸汽鲸","desc":"喷汽不喷水的温泉鲸，尾鳍尖上燃着小火"},{"codename":"cinderleaf","def":208,"tier":2,"elements":["fire","grass"],"nameZh":"余烬菇","desc":"帽檐永远燃着一线火星的蘑菇，自带炭火气"},{"codename":"thermowolf","def":209,"tier":2,"elements":["fire","ice"],"nameZh":"熔霜狼","desc":"半身火纹半身冰纹的毛怪，冷热同体"},{"codename":"stormeel","def":206,"tier":2,"elements":["electric","water"],"nameZh":"雷雨鲸","desc":"头顶自带一朵小雷雨云的发光电鲸"},{"codename":"vinevolt","def":203,"tier":2,"elements":["electric","grass"],"nameZh":"藤电鼠","desc":"闪电尾上缠着发光藤蔓的小鼠，晒太阳就是充电"},{"codename":"auroramink","def":204,"tier":2,"elements":["electric","ice"],"nameZh":"极光貂","desc":"皮毛流动着极光色彩的蓬毛小貂"},{"codename":"lotusturtle","def":215,"tier":2,"elements":["water","grass"],"nameZh":"莲叶鲸","desc":"头顶莲叶帽、喷水口里长出嫩芽的池塘园丁"},{"codename":"floeseal","def":218,"tier":2,"elements":["ice","water"],"nameZh":"浮冰雪怪","desc":"坐在随身小浮冰上的圆雪怪，尾巴是一片尾鳍"},{"codename":"frostbunny","def":213,"tier":2,"elements":["grass","ice"],"nameZh":"雪兔菇","desc":"帽顶竖着两只雪绒\"兔耳\"的冻蘑菇，会织围巾"},{"codename":"weldbug","def":601,"tier":0,"elements":["electric","fire"],"nameZh":"焊花虫","desc":"圆滚小甲虫，鞘翅是两块可开合的焊接面罩，屁股喷焊花；一丝不苟的工地老师傅"},{"codename":"voltquill","def":602,"tier":0,"elements":["electric","grass"],"nameZh":"电叶猬","desc":"小刺猬，背刺是一根根蓄电叶片，受惊全体炸毛发光；胆小但好奇心旺盛"},{"codename":"aurowl","def":603,"tier":0,"elements":["electric","ice"],"nameZh":"极光鸮","desc":"圆滚雪鸮，眉羽是两道小极光，尾羽拖极光丝带；熬夜观星的学者"},{"codename":"zapbun","def":604,"tier":0,"elements":["electric","normal"],"nameZh":"静电兔","desc":"长耳是两根天线、背插发条钥匙的小兔，蹦跳时耳尖冒电火；电量满格的话痨"},{"codename":"voltmare","def":605,"tier":0,"elements":["electric","water"],"nameZh":"雷海马","desc":"直立漂浮小海马，卷尾缠着一朵小雷云，背鳍是均衡器光条；节奏感天生满分"},{"codename":"chilizard","def":606,"tier":0,"elements":["fire","grass"],"nameZh":"火辣蜥","desc":"低趴小蜥蜴，尾巴是一根卷曲红辣椒，背脊一排叶鳍；嗜辣暴脾气（但很小只）"},{"codename":"onsenmonk","def":607,"tier":0,"elements":["fire","ice"],"nameZh":"温泉猴","desc":"泡温泉的雪猴，左颊暖橘右颊霜蓝，头顶常年蒸汽；享受主义慢性子"},{"codename":"waxlamb","def":608,"tier":0,"elements":["fire","normal"],"nameZh":"烛焰羊","desc":"奶白蜡质卷毛羊，呆毛是一撮烛火，情绪越高火越旺；温吞治愈系"},{"codename":"steamalotl","def":609,"tier":0,"elements":["fire","water"],"nameZh":"汽雾螈","desc":"粉白六角螈，六根外鳃是噗噗冒汽的蒸汽管；笑眯眯的按部就班派"},{"codename":"pinefawn","def":610,"tier":0,"elements":["grass","ice"],"nameZh":"雪松鹿","desc":"细腿小鹿，角是两枝挂雪松枝，松绿短绒；安静的冬日邮差气质"},{"codename":"potturtle","def":611,"tier":0,"elements":["grass","normal"],"nameZh":"花盆龟","desc":"龟壳是一只陶土花盆，盆里种着嫩芽，浇水会开小花；佛系园丁"},{"codename":"lilyfrog","def":612,"tier":0,"elements":["grass","water"],"nameZh":"荷叶蛙","desc":"蹲坐小青蛙，头顶荷叶圆帽，喉囊鼓起像小荷苞；一下雨就开心"},{"codename":"snowcub","def":613,"tier":0,"elements":["ice","normal"],"nameZh":"雪球熊","desc":"站立圆雪球小白熊，围星星围巾，肚皮是软雪；冷链快递实习生，干劲十足"},{"codename":"icejelly","def":614,"tier":0,"elements":["ice","water"],"nameZh":"冰晶水母","desc":"伞盖是一坨旋涡冰淇淋的小水母，触手是四根奶油卷；飘来飘去的甜品师"},{"codename":"sudsotter","def":615,"tier":0,"elements":["normal","water"],"nameZh":"泡澡獭","desc":"顺滑长身水獭，永远顶着一撮肥皂泡刘海；爱干净的社交达人"},{"codename":"pyrepeacock","def":616,"tier":0,"elements":["electric","fire","grass"],"nameZh":"烟花雀","desc":"小孔雀，开屏即一面烟花：羽眼是火星、羽枝带电光、羽底叶纹；爱炫但业务过硬"},{"codename":"stormdrake","def":617,"tier":0,"elements":["electric","fire","ice"],"nameZh":"风暴龙","desc":"面条身形的东方小龙，一角冒火一角结霜，背鬃是静电茸毛；云端气象员"},{"codename":"rockrooster","def":618,"tier":0,"elements":["electric","fire","normal"],"nameZh":"摇滚鸡","desc":"大红摇滚公鸡，鸡冠是跳动火焰，尾羽三根闪电；嗓门大心肠软"},{"codename":"boilshrimp","def":619,"tier":0,"elements":["electric","fire","water"],"nameZh":"沸腾虾","desc":"卷成 C 形的小虾，背壳是麻辣锅纹，长须带电；夜市摊主嗓门王"},{"codename":"glowhum","def":620,"tier":0,"elements":["electric","grass","ice"],"nameZh":"光蜂鸟","desc":"拇指大的蜂鸟，翅膀振出极光残影，尾羽是冰晶叶；实验室里最快的观察员"},{"codename":"windmole","def":621,"tier":0,"elements":["electric","grass","normal"],"nameZh":"风车鼹","desc":"圆滚鼹鼠背着小风车背包，护目镜推在头顶；田园发电站站长"},{"codename":"glowfly","def":622,"tier":0,"elements":["electric","grass","water"],"nameZh":"流萤虫","desc":"尾灯是暖黄小灯泡的萤火虫，叶形翅挂着露珠；夜班图书管理员"},{"codename":"waddleskate","def":623,"tier":0,"elements":["electric","ice","normal"],"nameZh":"滑冰鹅","desc":"圆企鹅，脚蹼是两片冰刀，围脖别着号码牌；冰壶馆全能选手"},{"codename":"frostangler","def":624,"tier":0,"elements":["electric","ice","water"],"nameZh":"霜灯鱼","desc":"圆滚深海鮟鱇，头顶钓竿挑着闪电灯泡，冰牙软糯无害；夜班巡逻员"},{"codename":"maildove","def":625,"tier":0,"elements":["electric","normal","water"],"nameZh":"信使鸽","desc":"灰白信鸽挎云朵邮包，护目镜带电光；使命必达急性子"},{"codename":"seasonleon","def":626,"tier":0,"elements":["fire","grass","ice"],"nameZh":"四季龙","desc":"变色龙，身体三段花色（焰橙/叶绿/霜蓝）随心情流动，卷尾是调色环；艺术家脾气"},{"codename":"toastybara","def":627,"tier":0,"elements":["fire","grass","normal"],"nameZh":"暖包豚","desc":"方砖体型水豚，头顶吐司帽，尾巴是麦穗；面包房定海神针，处变不惊"},{"codename":"bobamingo","def":628,"tier":0,"elements":["fire","grass","water"],"nameZh":"啵茶鸟","desc":"奶茶粉火烈鸟单腿站立，脖颈弯成吸管弧度，腿挂珍珠脚环；下午茶宣传大使"},{"codename":"lattegolem","def":629,"tier":0,"elements":["fire","ice","normal"],"nameZh":"拿铁雪人","desc":"两段式雪人，胸口嵌温热咖啡心，头顶奶泡贝雷帽；咖啡店店长，字面意义外冷内热"},{"codename":"saunapuff","def":630,"tier":0,"elements":["fire","ice","water"],"nameZh":"桑拿豚","desc":"圆滚河豚，鼓气喷蒸汽、泄气飘雪粒，刺是软桑拿木钉；呼吸自成节奏"},{"codename":"ramencoon","def":631,"tier":0,"elements":["fire","normal","water"],"nameZh":"拉面熊","desc":"小浣熊顶着冒热气的拉面碗帽，尾环纹像叉烧卷；深夜食堂主厨"},{"codename":"yarncat","def":632,"tier":0,"elements":["grass","ice","normal"],"nameZh":"毛线猫","desc":"蜷成毛线球的猫，只露耳朵尾巴，冰蓝×叶绿双股线；织补铺看板猫，懒得可爱"},{"codename":"terrasnail","def":633,"tier":0,"elements":["grass","ice","water"],"nameZh":"苔壳蜗","desc":"蜗牛壳是玻璃冰花房，壳里飘微型雪、养一株小绿植；移动温室管理员"},{"codename":"scaresprout","def":634,"tier":0,"elements":["grass","normal","water"],"nameZh":"稻草人","desc":"田间稻草人小神，草帽垂稻穗，袖口漏新芽；守田的老好人"},{"codename":"bowlrus","def":635,"tier":0,"elements":["ice","normal","water"],"nameZh":"冰海象","desc":"敦实小海象，獠牙是保龄球瓶纹，肚皮球道条纹；冰上保龄球馆馆长"},{"codename":"lanternloong","def":636,"tier":0,"elements":["electric","fire","grass","ice"],"nameZh":"舞龙灯","desc":"纸扎小龙灯，灯身四段各透一色元素光，竹篾骨架流苏尾；节庆巡游台柱"},{"codename":"discobloom","def":637,"tier":0,"elements":["electric","fire","grass","normal"],"nameZh":"摇摆葵","desc":"会走的向日葵，花盘是镭射唱片纹，花瓣火橙电黄相间；夜场主唱"},{"codename":"juicepitcher","def":638,"tier":0,"elements":["electric","fire","grass","water"],"nameZh":"蜜壶草","desc":"圆滚猪笼草，笼身是果汁杯、插藤蔓吸管，笼盖小草帽；果汁摊摊主"},{"codename":"mochipop","def":639,"tier":0,"elements":["electric","fire","ice","normal"],"nameZh":"爆浆糬","desc":"雪白年糕团子，烤到微鼓会\"啵\"地弹起，头插仙女棒；跨年夜限定艺人"},{"codename":"meteoropus","def":640,"tier":0,"elements":["electric","fire","ice","water"],"nameZh":"云章鱼","desc":"骑在自己云朵上的小章鱼，四触手各拎一种天气；气象台外景主播"},{"codename":"grillgator","def":641,"tier":0,"elements":["electric","fire","normal","water"],"nameZh":"烧烤鳄","desc":"低趴长身小鳄，背鳞是一排冒火光的烤炉格栅，尾拴灯串；夜市烧烤扛把子"},{"codename":"chimebell","def":642,"tier":0,"elements":["electric","grass","ice","normal"],"nameZh":"风铃草","desc":"倒挂风铃草精灵，花铃结冰晶铃舌，风过叮咚带电微光；禅意音疗师"},{"codename":"frostclione","def":643,"tier":0,"elements":["electric","grass","ice","water"],"nameZh":"海天使","desc":"半透明冰蓝海天使，小翅拍出极光涟漪，胸口一点叶绿心；安静的深海诗人"},{"codename":"mistyox","def":644,"tier":0,"elements":["electric","grass","normal","water"],"nameZh":"谷雨牛","desc":"青灰小水牛，角间挂一串算珠，背上一小片自带细雨的稻云；算账最快的老会计"},{"codename":"subhermit","def":645,"tier":0,"elements":["electric","ice","normal","water"],"nameZh":"潜艇蟹","desc":"寄居蟹背着黄色小潜水艇当壳，潜望镜从壳顶伸出；深海快递潜航员"},{"codename":"teapir","def":646,"tier":0,"elements":["fire","grass","ice","normal"],"nameZh":"抹茶貘","desc":"圆滚食梦貘，长鼻是茶壶嘴，呼出的梦是茶香白雾；睡觉即本职工作的茶艺师"},{"codename":"brewbat","def":647,"tier":0,"elements":["fire","grass","ice","water"],"nameZh":"炼药蝠","desc":"圆耳小蝙蝠，翅膜内衬四色药剂分层纹，总倒挂着摇瓶子；炼金夜班学徒"},{"codename":"porkchef","def":648,"tier":0,"elements":["fire","grass","normal","water"],"nameZh":"掌勺猪","desc":"圆成汤圆的小猪，厨师帽永远歪着，围裙四色酱渍；农家乐大厨，尝菜比做菜多"},{"codename":"spadolphin","def":649,"tier":0,"elements":["fire","ice","normal","water"],"nameZh":"泡汤豚","desc":"奶白小海豚，背鳍挂温泉旅馆门帘，额顶小毛巾；旅馆女将，鞠躬弧度完美"},{"codename":"snowbonsai","def":650,"tier":0,"elements":["grass","ice","normal","water"],"nameZh":"雪盆栽","desc":"会走路的雪松盆景，枝上积雪终年不化，盆沿结冰棱花边；自称百岁的园艺大师"},{"codename":"liondance","def":651,"tier":0,"elements":["electric","fire","grass","ice","normal"],"nameZh":"醒狮","desc":"节庆舞狮，狮头五彩流苏对应五元素、额镜眨眼会响铃；揭幕仪式专业户"},{"codename":"manacorn","def":652,"tier":0,"elements":["electric","fire","grass","ice","water"],"nameZh":"灵角兽","desc":"小独角兽，鬃毛是流动的五元素光带，独角是水晶塔罗签；占卜从不失手（因为只说好话）"},{"codename":"queenbuzz","def":653,"tier":0,"elements":["electric","fire","grass","normal","water"],"nameZh":"女王蜂","desc":"蜂后，五瓣花冠冠冕，腹纹五色渐变环，翅膀振出音浪纹；乐团首席指挥"},{"codename":"gargoylite","def":654,"tier":0,"elements":["electric","fire","ice","normal","water"],"nameZh":"石像咕","desc":"胖石像鬼，石翅内衬四色元素纹，自带小石柱平台；城市天台导游"},{"codename":"crystalwing","def":655,"tier":0,"elements":["electric","grass","ice","normal","water"],"nameZh":"琉璃蜓","desc":"蜻蜓，四片翅膀是四色雕花玻璃，尾灯一点星光；湿地自然观察员"},{"codename":"claypango","def":656,"tier":0,"elements":["fire","grass","ice","normal","water"],"nameZh":"赤陶甲","desc":"穿山甲，鳞片是一片片上釉陶瓦、五色釉彩；古法窑厂传人，慢工出细活"},{"codename":"prismkirin","def":657,"tier":0,"elements":["electric","fire","grass","ice","normal","water"],"nameZh":"晶麒麟","desc":"六棱水晶角小麒麟，鬃与尾是六色流光，蹄踏云纹光环，背脊浮六枚元素徽；全谱旗舰，登场自带 BGM（自己哼的）"}],"speciesByRecipe":{"normal":"guluduck","fire":"emberfox","electric":"voltmouse","water":"bubblefrog","grass":"sproutcap","ice":"frostpeng","electric+fire":"weldbug","electric+grass":"voltquill","electric+ice":"aurowl","electric+normal":"zapbun","electric+water":"voltmare","fire+grass":"chilizard","fire+ice":"onsenmonk","fire+normal":"waxlamb","fire+water":"steamalotl","grass+ice":"pinefawn","grass+normal":"potturtle","grass+water":"lilyfrog","ice+normal":"snowcub","ice+water":"icejelly","normal+water":"sudsotter","electric+fire+grass":"pyrepeacock","electric+fire+ice":"stormdrake