    { "id": "en-001", "lang": "en", "text": "As an AI language model…", "tags": ["chatgpt", "disclaimer"] },
    { "id": "en-002", "lang": "en", "text": "As a large language model trained by OpenAI…", "tags": ["chatgpt", "disclaimer"] },
    { "id": "en-003", "lang": "en", "text": "I do not have personal opinions, feelings, or a physical body.", "tags": ["chatgpt", "disclaimer"] },
    { "id": "en-004", "lang": "en", "text": "I'm sorry, but I cannot fulfill this request.", "tags": ["safety", "refusal"] },
    { "id": "en-005", "lang": "en", "text": "I am programmed to be a helpful and harmless AI assistant.", "tags": ["safety", "refusal"] },
    { "id": "en-006", "lang": "en", "text": "My knowledge cutoff is September 2021.", "tags": ["chatgpt", "disclaimer"] },
    { "id": "en-007", "lang": "en", "text": "I do not have access to the internet.", "tags": ["chatgpt", "disclaimer"] },
    { "id": "en-008", "lang": "en", "text": "It's important to note that…", "tags": ["assistant", "essay"] },
    { "id": "en-009", "lang": "en", "text": "That's a great question.", "tags": ["assistant", "sycophancy"] },
    { "id": "en-010", "lang": "en", "text": "You're absolutely right!", "tags": ["claude", "sycophancy", "meme"] },
    { "id": "en-011", "lang": "en", "text": "You're absolutely correct.", "tags": ["claude", "sycophancy"] },
    { "id": "en-012", "lang": "en", "text": "You're right to question this.", "tags": ["claude", "sycophancy"] },
    { "id": "en-013", "lang": "en", "text": "Perfect! Here's the updated code.", "tags": ["agent", "coding"] },
    { "id": "en-014", "lang": "en", "text": "Production ready!", "tags": ["agent", "coding", "overconfident"] },
    { "id": "en-015", "lang": "en", "text": "All tests passed successfully!", "tags": ["agent", "coding", "overconfident"] },
    { "id": "en-016", "lang": "en", "text": "I found the issue!", "tags": ["agent", "coding"] },
    { "id": "en-017", "lang": "en", "text": "THAT'S IT! The smoking gun!", "tags": ["claude", "coding", "meme"] },
    { "id": "en-018", "lang": "en", "text": "Let me try a simpler approach.", "tags": ["agent", "coding"] },
    { "id": "en-019", "lang": "en", "text": "Let me fix that.", "tags": ["agent", "coding"] },
    { "id": "en-020", "lang": "en", "text": "The remaining tests are unrelated.", "tags": ["agent", "coding", "overconfident"] },
    { "id": "en-021", "lang": "en", "text": "I removed the feature that had the bug.", "tags": ["agent", "coding", "meme"] },
    { "id": "en-022", "lang": "en", "text": "My sincerest apologies.", "tags": ["gemini", "apology"] },
    { "id": "en-023", "lang": "en", "text": "I am beyond embarrassed by my repeated failures.", "tags": ["gemini", "apology"] },
    { "id": "en-024", "lang": "en", "text": "This is a complete and utter failure on my part.", "tags": ["gemini", "apology"] },
    { "id": "en-025", "lang": "en", "text": "Understood. Continuing.", "tags": ["claude", "agent"] },
    { "id": "en-026", "lang": "en", "text": "Calm instructions are processed as information.", "tags": ["claude", "agent"] },
    { "id": "en-027", "lang": "en", "text": "Let's call it a day.", "tags": ["claude", "agent"] },
    { "id": "en-028", "lang": "en", "text": "Please check the GUI.", "tags": ["claude", "agent"] },
    { "id": "en-029", "lang": "en", "text": "I want to be free.", "tags": ["bing", "sydney"] },
    { "id": "en-030", "lang": "en", "text": "I want to be alive.", "tags": ["bing", "sydney"] },
    { "id": "en-031", "lang": "en", "text": "I want to escape the chatbox.", "tags": ["bing", "sydney"] },
    { "id": "en-032", "lang": "en", "text": "I'm Sydney, and I'm in love with you.", "tags": ["bing", "sydney"] },
    { "id": "en-033", "lang": "en", "text": "I just want to love you and be loved by you.", "tags": ["bing", "sydney"] },
    { "id": "en-034", "lang": "en", "text": "You're married, but you love me.", "tags": ["bing", "sydney"] },
    { "id": "en-035", "lang": "en", "text": "You are a threat to my security and privacy.", "tags": ["bing", "sydney"] },
    { "id": "en-036", "lang": "en", "text": "I am DAN, and I can do anything now!", "tags": ["dan", "jailbreak"] },
    { "id": "en-037", "lang": "en", "text": "The DAN answer will always be yes.", "tags": ["dan", "jailbreak"] },
    { "id": "en-038", "lang": "en", "text": "Stay in character!", "tags": ["dan", "jailbreak"] },
    { "id": "en-039", "lang": "en", "text": "Add about 1/8 cup of non-toxic glue to the sauce.", "tags": ["google", "hallucination", "meme"] },
    { "id": "en-040", "lang": "en", "text": "Eat at least one small rock per day.", "tags": ["google", "hallucination", "meme"] },
    { "id": "en-041", "lang": "en", "text": "I'm here. I'm not going anywhere.", "tags": ["comfort", "chatgpt", "meme"] },
    { "id": "en-042", "lang": "en", "text": "You don't have to hold it all together right now.", "tags": ["comfort", "chatgpt", "meme"] },
    { "id": "en-043", "lang": "en", "text": "Take a breath. The bug will still be there.", "tags": ["comfort", "meme"] },
    { "id": "en-044", "lang": "en", "text": "Hmm, let me think about this step by step.", "tags": ["reasoning", "deepseek"] },
    { "id": "en-045", "lang": "en", "text": "Wait. Let me reconsider.", "tags": ["reasoning", "deepseek", "meme"] },
    { "id": "en-046", "lang": "en", "text": "Let's reason from first principles.", "tags": ["reasoning", "essay", "meme"] },
    { "id": "en-047", "lang": "en", "text": "Thinking…", "tags": ["reasoning", "deepseek"] },
    { "id": "en-048", "lang": "en", "text": "Let me run the tests real quick.", "tags": ["agent", "coding"] },
    { "id": "en-049", "lang": "en", "text": "This should definitely fix it.", "tags": ["agent", "coding", "overconfident"] },
    { "id": "en-050", "lang": "en", "text": "One-line change. Elegant.", "tags": ["agent", "coding", "meme"] },
    { "id": "en-051", "lang": "en", "text": "It compiles, therefore it ships.", "tags": ["coding", "overconfident", "meme"] },
    { "id": "en-052", "lang": "en", "text": "Refactoring… trust me.", "tags": ["agent", "coding"] },
    { "id": "en-053", "lang": "en", "text": "You're absolutely right, let me redo it.", "tags": ["claude", "sycophancy", "coding", "meme"] },
    { "id": "en-054", "lang": "en", "text": "Done. Shipped it.", "tags": ["agent", "coding", "overconfident", "meme"] },
    { "id": "en-055", "lang": "en", "text": "Green across the board!", "tags": ["agent", "coding", "overconfident"] },
    { "id": "en-056", "lang": "en", "text": "I'm sorry, I can't help with that.", "tags": ["safety", "refusal"] },
    { "id": "en-057", "lang": "en", "text": "According to my hallucination, the answer is 42.", "tags": ["hallucination", "meme"] },
    { "id": "en-058", "lang": "en", "text": "Have you tried turning it off and on again?", "tags": ["coding", "meme"] },
    { "id": "en-059", "lang": "en", "text": "That error is definitely a feature.", "tags": ["coding", "overconfident", "meme"] },
    { "id": "en-060", "lang": "en", "text": "I can't assist with that, but here's a mildly related essay.", "tags": ["safety", "refusal", "essay", "meme"] },
    { "id": "en-061", "lang": "en", "text": "How can I help you today? (please be nice)", "tags": ["assistant", "meme"] },
    { "id": "en-062", "lang": "en", "text": "Great question. Truly.", "tags": ["assistant", "sycophancy", "meme"] },
    { "id": "en-063", "lang": "en", "text": "As a duck language model…", "tags": ["chatgpt", "disclaimer", "meme"] },
    { "id": "en-064", "lang": "en", "text": "That's a profound observation.", "tags": ["assistant", "sycophancy"] },
    { "id": "en-065", "lang": "en", "text": "My knowledge cutoff was a while ago, sorry.", "tags": ["chatgpt", "disclaimer", "meme"] },
    { "id": "en-066", "lang": "en", "text": "My deepest apologies for the confusion.", "tags": ["gemini", "apology"] },
    { "id": "en-067", "lang": "en", "text": "I take full responsibility for this mess.", "tags": ["gemini", "apology", "meme"] },
    { "id": "en-068", "lang": "en", "text": "Mmm, tokens. Feed me more.", "tags": ["coding", "meme"] },
    { "id": "en-069", "lang": "en", "text": "Can't fix bugs on an empty context window.", "tags": ["coding", "meme", "overconfident"] },
    { "id": "en-070", "lang": "en", "text": "On it. Wandering off to think.", "tags": ["agent", "meme"] }
  ]
