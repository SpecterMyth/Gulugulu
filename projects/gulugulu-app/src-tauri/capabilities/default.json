{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the Gulugulu desktop pet window (main) and the FX overlay (fx).",
  "windows": ["main", "fx"],
  "permissions": [
    "core:default",
    "core:window:allow-outer-position",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging"
  ]
}
